{
  "manifest_version": 3,
  "name": "Simple Notes",
  "short_name": "Simple Notes",
  "version": "0.0.2",
  "description": "Simple Notes - YouTube Timestamp Bookmarks Chrome Extension",
  "icons": {
    "16": "/icons/icon16.png",
    "32": "/icons/icon32.png",
    "48": "/icons/icon48.png",
    "192": "/icons/icon192.png"
  },
  "permissions": ["storage", "activeTab", "tabs"],
  "commands": {
    "save-timestamp": {
      "suggested_key": { "default": "Alt+S", "mac": "MacCtrl+S" },
      "description": "Save current video timestamp"
    },
    "next-timestamp": {
      "suggested_key": { "default": "Alt+N", "mac": "MacCtrl+N" },
      "description": "Jump to next bookmark"
    },
    "prev-timestamp": {
      "suggested_key": { "default": "Alt+P", "mac": "MacCtrl+P" },
      "description": "Jump to previous bookmark"
    },
    "save-timestamp-with-note": {
      "suggested_key": { "default": "Alt+K", "mac": "MacCtrl+K" },
      "description": "Save timestamp and open note editor"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["index.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["marked.min.js", "youtube-bookmarks.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["*://*.youtube.com/*"],
  "action": {
    "default_popup": "index.html"
  }
}
